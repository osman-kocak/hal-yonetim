generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SessionStatus {
  ACTIVE
  COMPLETED
}

enum UserRole {
  ADMIN
  DEPO
  OPERATOR
  ACCOUNTING
}

enum LedgerEntryType {
  MARKET_INVOICE       // İrsaliye → bayi borcu (otomatik, Exit ile)
  MARKET_PAYMENT       // Tahsilat (manuel)
  MARKET_ADJUSTMENT    // Bayi düzeltme (signed)
  PRODUCER_DEBT        // Üreticiye borç (manuel)
  PRODUCER_PAYMENT     // Üreticiye ödeme (manuel)
  PRODUCER_ADJUSTMENT  // Üretici düzeltme (signed)
}

enum CaseMovementType {
  MARKET_OUT      // Bayiye gönderildi (otomatik, Exit ile)
  MARKET_IN       // Bayiden iade alındı (manuel)
  MARKET_INIT     // Bayi başlangıç bakiyesi
  MARKET_ADJUST   // Bayi düzeltme (qty signed olabilir)
  DRIVER_OUT      // Şoföre kasa verildi (manuel)
  DRIVER_IN       // Şoförden iade
  DRIVER_INIT     // Şoför başlangıç bakiyesi
  DRIVER_ADJUST   // Şoför düzeltme
}

model Driver {
  id              Int              @id @default(autoincrement())
  name            String
  vehicleSessions VehicleSession[]
  caseMovements   CaseMovement[]
  producers       Producer[]
  createdAt       DateTime         @default(now())
}

model Producer {
  id            Int            @id @default(autoincrement())
  name          String
  driver        Driver?        @relation(fields: [driverId], references: [id], onDelete: SetNull)
  driverId      Int?
  entries       Entry[]
  ledgerEntries LedgerEntry[]
  createdAt     DateTime       @default(now())

  @@index([driverId])
}

model VehicleSession {
  id        Int           @id @default(autoincrement())
  driver    Driver        @relation(fields: [driverId], references: [id], onDelete: Restrict)
  driverId  Int
  status    SessionStatus @default(ACTIVE)
  entries   Entry[]
  createdAt DateTime      @default(now())
}

model Product {
  id      Int     @id @default(autoincrement())
  name    String  @unique
  entries Entry[]
  prices  Price[]
}

model Quality {
  id      Int     @id @default(autoincrement())
  name    String  @unique
  entries Entry[]
  prices  Price[]
}

model Market {
  id            Int            @id @default(autoincrement())
  no            Int            @unique
  name          String
  entries       Entry[]
  exits         Exit[]
  caseMovements CaseMovement[]
  ledgerEntries LedgerEntry[]
  transfersFrom Transfer[]     @relation("TransferFrom")
  transfersTo   Transfer[]     @relation("TransferTo")
}

model Entry {
  id               Int            @id @default(autoincrement())
  vehicleSession   VehicleSession @relation(fields: [vehicleSessionId], references: [id], onDelete: Restrict)
  vehicleSessionId Int
  product          Product        @relation(fields: [productId], references: [id], onDelete: Restrict)
  productId        Int
  producer         Producer?      @relation(fields: [producerId], references: [id], onDelete: Restrict)
  producerId       Int?
  quality          Quality?       @relation(fields: [qualityId], references: [id], onDelete: Restrict)
  qualityId        Int?
  caseCount        Int
  weight           Float
  weak             Boolean        @default(false)
  market           Market         @relation(fields: [marketId], references: [id], onDelete: Restrict)
  marketId         Int
  exitItems        ExitItem[]
  transfers        Transfer[]
  createdAt        DateTime       @default(now())
}

model Exit {
  id           Int           @id @default(autoincrement())
  market       Market        @relation(fields: [marketId], references: [id], onDelete: Restrict)
  marketId     Int
  items        ExitItem[]
  caseMovement CaseMovement?
  ledgerEntry  LedgerEntry?
  createdAt    DateTime      @default(now())
  createdBy    String?
  editedAt     DateTime?
  editedBy     String?
}

model ExitItem {
  id      Int     @id @default(autoincrement())
  exit    Exit    @relation(fields: [exitId], references: [id], onDelete: Cascade)
  exitId  Int
  entry   Entry   @relation(fields: [entryId], references: [id], onDelete: Restrict)
  entryId Int
  loaded  Boolean @default(true)

  @@unique([exitId, entryId])
}

// Günlük ürün fiyatları — muhasebeci admin panelden girer
model Price {
  id         Int      @id @default(autoincrement())
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId  Int
  quality    Quality  @relation(fields: [qualityId], references: [id], onDelete: Cascade)
  qualityId  Int
  pricePerKg Float
  date       DateTime @db.Date
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt
  updatedBy  String?

  @@unique([productId, qualityId, date])
}

// Finansal hareket — bayi (müşteri) ve üretici cari hesapları
model LedgerEntry {
  id         Int             @id @default(autoincrement())
  type       LedgerEntryType
  amount     Float
  market     Market?         @relation(fields: [marketId], references: [id], onDelete: Restrict)
  marketId   Int?
  producer   Producer?       @relation(fields: [producerId], references: [id], onDelete: Restrict)
  producerId Int?
  exit       Exit?           @relation(fields: [exitId], references: [id], onDelete: Cascade)
  exitId     Int?            @unique
  note       String?
  occurredAt DateTime        @default(now())
  createdAt  DateTime        @default(now())
  createdBy  String?

  @@index([marketId, occurredAt])
  @@index([producerId, occurredAt])
  @@index([type, occurredAt])
}

// Kasa hareketi — bayi & şoför kasa takibi
model CaseMovement {
  id         Int              @id @default(autoincrement())
  type       CaseMovementType
  qty        Int
  market     Market?          @relation(fields: [marketId], references: [id], onDelete: Restrict)
  marketId   Int?
  driver     Driver?          @relation(fields: [driverId], references: [id], onDelete: Restrict)
  driverId   Int?
  exit       Exit?            @relation(fields: [exitId], references: [id], onDelete: Cascade)
  exitId     Int?             @unique
  note       String?
  occurredAt DateTime         @default(now())
  createdAt  DateTime         @default(now())
  createdBy  String?

  @@index([marketId, occurredAt])
  @@index([driverId, occurredAt])
}

// Sistemi kullanan kullanıcılar — operatörler (sadece referans),
// adminler ve depo personeli (giriş yapabilir)
model User {
  id           Int      @id @default(autoincrement())
  name         String
  username     String?  @unique
  passwordHash String?
  role         UserRole @default(OPERATOR)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
}

// Depodan başka pazara transfer geçmişi
model Transfer {
  id           Int      @id @default(autoincrement())
  entry        Entry    @relation(fields: [entryId], references: [id], onDelete: Restrict)
  entryId      Int
  fromMarket   Market   @relation("TransferFrom", fields: [fromMarketId], references: [id], onDelete: Restrict)
  fromMarketId Int
  toMarket     Market   @relation("TransferTo", fields: [toMarketId], references: [id], onDelete: Restrict)
  toMarketId   Int
  note         String?
  createdBy    String?
  createdAt    DateTime @default(now())

  @@index([entryId])
  @@index([fromMarketId, createdAt])
  @@index([toMarketId, createdAt])
}
