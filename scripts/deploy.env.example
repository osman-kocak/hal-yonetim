# Deploy konfigürasyonu örneği
# Bu dosyayı `scripts/deploy.env` adıyla kopyala ve kendi VPS bilgilerinle doldur.
# `scripts/deploy.env` .gitignore'da olduğu için git'e gitmez.

VPS_HOST="vps.example.com"
VPS_PORT="22"
VPS_USER="root"
VPS_KEY="$HOME/.ssh/id_rsa"

BACKEND_REMOTE="/var/www/example.com/backend"
FRONTEND_REMOTE="/var/www/example.com/public"
PM2_NAME="example-backend"
